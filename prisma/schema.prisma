// DareXAI — AI Business Operations Platform
// Multi-tenant: every business-owned row carries tenantId. App-layer scoping
// in middleware + (production) Postgres RLS. Cascade deletes scoped to tenant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled (pgbouncer)
  directUrl = env("DIRECT_URL")     // direct for migrations
}

// ─────────────── Enums ───────────────

enum Role {
  OWNER
  MEMBER
}

enum OpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum TaskStatus {
  PENDING
  DONE
  CANCELLED
}

enum Channel {
  WHATSAPP
  EMAIL
  CALL
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum AiRole {
  USER
  ASSISTANT
  TOOL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
  AI_TOOL_CALL
  WORKFLOW_RUN
  WHATSAPP_SEND
}

// ─────────────── Tenancy + Auth ───────────────

model Tenant {
  id           String   @id @default(cuid())
  name         String
  // Business onboarding context — injected into AI agent system prompt.
  industry     String?
  description  String?
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now())

  users         User[]
  contacts      Contact[]
  opportunities Opportunity[]
  tasks         Task[]
  conversations Conversation[]
  aiThreads     AiConversation[]
  auditLogs     AuditLog[]

  @@index([id])
}

model User {
  id         String   @id @default(cuid())
  tenantId   String
  email      String   @unique
  name       String?
  avatarUrl  String?
  googleSub  String   @unique          // OAuth subject
  role       Role     @default(OWNER)
  createdAt  DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([tenantId])
}

// Rotation: each refresh issues new row, old marked replaced. Reuse of a
// replaced/revoked token => revoke whole family (familyId) = theft detection.
model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  familyId    String                       // chain id across rotations
  tokenHash   String    @unique            // store hash, never raw
  expiresAt   DateTime
  revoked     Boolean   @default(false)
  replacedById String?  @unique
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

// ─────────────── CRM ───────────────

model Contact {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  phone      String?                      // E.164 for WhatsApp
  email      String?
  company    String?
  tags       String[]
  createdAt  DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  conversations Conversation[]
  tasks         Task[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Opportunity {
  id            String           @id @default(cuid())
  tenantId      String
  contactId     String
  title         String
  stage         OpportunityStage @default(NEW)
  valueCents    Int              @default(0)   // money in cents, never float
  score         Int?                            // AI qualification 0-100
  nextBestAction String?                        // AI-generated NBA
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@index([tenantId])
  @@index([tenantId, stage])
}

model Task {
  id            String     @id @default(cuid())
  tenantId      String
  contactId     String?
  opportunityId String?
  title         String
  dueAt         DateTime?
  status        TaskStatus @default(PENDING)
  createdByAi   Boolean    @default(false)
  createdAt     DateTime   @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([tenantId, status])
}

// ─────────────── Unified Inbox (P1) ───────────────
// One Conversation per contact+channel. Messages stream into timeline.
model Conversation {
  id          String    @id @default(cuid())
  tenantId    String
  contactId   String
  channel     Channel
  // AI-derived rollups, recomputed on new inbound:
  aiSummary   String?
  intent      String?
  sentiment   Sentiment?
  nextAction  String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, contactId, channel])
  @@index([tenantId, channel])
}

model Message {
  id             String    @id @default(cuid())
  tenantId       String
  conversationId String
  direction      Direction
  body           String
  externalId     String?                  // Meta msg id, for idempotent webhooks
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([externalId])
  @@index([tenantId, conversationId])
}

// ─────────────── AI Agent (separate from inbox) ───────────────

model AiConversation {
  id        String      @id @default(cuid())
  tenantId  String
  userId    String
  title     String?
  createdAt DateTime    @default(now())

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([tenantId, userId])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           AiRole
  content        String
  // Explainability: short "why" string the agent must emit per recommendation.
  reasoning      String?
  // Tool-calling audit: which tool, args, result (JSON).
  toolName       String?
  toolPayload    Json?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─────────────── Audit (security + workflow trace) ───────────────

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  userId     String?
  action     AuditAction
  entity     String?                      // e.g. "Opportunity"
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}
